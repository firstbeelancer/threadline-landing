---
const year = new Date().getFullYear();
const { locale = 'ru' } = Astro.props;
const isEn = locale === 'en';
const t = isEn
  ? {
      description: 'A visual workspace for ideas, files, relationships, and project context.',
      product: 'Product',
      features: 'Features',
      how: 'How it works',
      formats: 'Card formats',
      pricing: 'Pricing',
      capabilities: 'Capabilities',
      fileStorage: 'File storage',
      linksVersions: 'Links and versions',
      aiAgents: 'AI agents',
      crossPlatform: 'Cross-platform access',
      contacts: 'Contacts',
      openApp: 'Open app',
      support: 'Support',
      terms: 'Terms of Use',
      privacy: 'Privacy Policy',
      rights: 'All rights reserved.',
      made: 'Made by the tigerapps team',
      privacyHref: '/en/legal/privacy',
    }
  : {
      description: 'Визуальное пространство для идей, файлов, связей и проектного контекста.',
      product: 'Продукт',
      features: 'Возможности',
      how: 'Как работает',
      formats: 'Форматы карточек',
      pricing: 'Тарифы',
      capabilities: 'Возможности',
      fileStorage: 'Хранение файлов',
      linksVersions: 'Связи и версии',
      aiAgents: 'ИИ-агенты',
      crossPlatform: 'Кроссплатформенность',
      contacts: 'Контакты',
      openApp: 'Открыть приложение',
      support: 'Поддержка',
      terms: 'Условия использования',
      privacy: 'Политика приватности',
      rights: 'Все права защищены.',
      made: 'Сделано в команде tigerapps',
      privacyHref: '/legal/privacy',
    };
---
<footer class="site-footer px-6 py-14">
  <div class="max-w-[1100px] mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2.5 mb-3">
          <img src="/icon-192.png" alt="THREADLINE" class="w-6 h-6 rounded-[6px]" />
          <span class="font-display text-[13px] font-bold tracking-tight">
            THREAD<span class="text-gradient">LINE</span>
          </span>
        </div>
        <p class="text-[12px] leading-relaxed max-w-[240px]" style="color: hsl(255,8%,45%);">
          {t.description}
        </p>
      </div>
      <div>
        <div class="text-[10.5px] font-semibold uppercase tracking-widest mb-3" style="color: hsl(255,8%,40%);">{t.product}</div>
        <ul class="space-y-2 text-[12.5px]" style="color: hsl(255,8%,60%);">
          <li><a href="/#features" class="hover:text-white transition-colors">{t.features}</a></li>
          <li><a href="/#how" class="hover:text-white transition-colors">{t.how}</a></li>
          <li><a href="/#formats" class="hover:text-white transition-colors">{t.formats}</a></li>
          <li><a href="/#pricing" class="hover:text-white transition-colors">{t.pricing}</a></li>
        </ul>
      </div>
      <div>
        <div class="text-[10.5px] font-semibold uppercase tracking-widest mb-3" style="color: hsl(255,8%,40%);">{t.capabilities}</div>
        <ul class="space-y-2 text-[12.5px]" style="color: hsl(255,8%,60%);">
          <li><a href="/#features" class="hover:text-white transition-colors">{t.fileStorage}</a></li>
          <li><a href="/#features" class="hover:text-white transition-colors">{t.linksVersions}</a></li>
          <li><a href="/#features" class="hover:text-white transition-colors">{t.aiAgents}</a></li>
          <li><a href="/#features" class="hover:text-white transition-colors">{t.crossPlatform}</a></li>
        </ul>
      </div>
      <div>
        <div class="text-[10.5px] font-semibold uppercase tracking-widest mb-3" style="color: hsl(255,8%,40%);">{t.contacts}</div>
        <ul class="space-y-2 text-[12.5px]" style="color: hsl(255,8%,60%);">
          <li><a href="https://threadline.tigerapps.pro/login" class="hover:text-white transition-colors">{t.openApp}</a></li>
          <li><a href="mailto:support@threadline.tigerapps.pro" class="hover:text-white transition-colors">{t.support}</a></li>
          <li><a href="/legal/terms" class="hover:text-white transition-colors">{t.terms}</a></li>
          <li><a href={t.privacyHref} class="hover:text-white transition-colors">{t.privacy}</a></li>
        </ul>
      </div>
    </div>
    <div class="flex items-center justify-between text-[11.5px] pt-6 hairline-top" style="color: hsl(255,8%,40%);">
      <div>© {year} THREADLINE. {t.rights}</div>
      <div>{t.made}</div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(255,255,255,0.05);
    background: linear-gradient(180deg, transparent 0%, rgba(7,7,13,0.36) 100%);
  }
</style>
