---
import { detectLang, getStrings, type Lang } from '../i18n/dict';

export interface Props {
  lang?: Lang;
}

const { lang = detectLang(Astro.url.pathname) } = Astro.props;
const s = getStrings(lang);
const year = new Date().getFullYear();

const pathFor = (target: Lang) => (target === 'en' ? '/en' : '/');
const docPath = (slug: string, target: Lang) => (target === 'en' ? `/en/${slug}` : `/${slug}`);
---

<footer class="px-6 py-14 hairline-top">
  <div class="max-w-[1100px] mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2.5 mb-3">
          <img src="/icon-192.png" alt="THREADLINE" class="w-6 h-6 rounded-[6px]" />
          <span class="font-display text-[13px] font-bold tracking-tight">
            THREAD<span class="text-gradient">LINE</span>
          </span>
        </div>
        <p class="text-[12px] leading-relaxed max-w-[240px]" style="color: hsl(255,8%,45%);">
          {s.footer.tagline}
        </p>
      </div>
      <div>
        <div class="text-[10.5px] font-semibold uppercase tracking-widest mb-3" style="color: hsl(255,8%,40%);">{s.footer.product}</div>
        <ul class="space-y-2 text-[12.5px]" style="color: hsl(255,8%,60%);">
          <li><a href={pathFor(lang) + '#features'} class="hover:text-white transition-colors">{s.footer.product_features}</a></li>
          <li><a href={pathFor(lang) + '#pricing'} class="hover:text-white transition-colors">{s.footer.product_pricing}</a></li>
          <li><a href="https://threadline.tigerapps.pro/changelog" class="hover:text-white transition-colors">{s.footer.product_changelog}</a></li>
          <li><a href="https://threadline.tigerapps.pro" class="hover:text-white transition-colors">{s.footer.product_status}</a></li>
        </ul>
      </div>
      <div>
        <div class="text-[10.5px] font-semibold uppercase tracking-widest mb-3" style="color: hsl(255,8%,40%);">{s.footer.resources}</div>
        <ul class="space-y-2 text-[12.5px]" style="color: hsl(255,8%,60%);">
          <li><a href={docPath('docs', lang)} class="hover:text-white transition-colors">{s.footer.resources_docs}</a></li>
          <li><a href={docPath('blog', lang)} class="hover:text-white transition-colors">{s.footer.resources_blog}</a></li>
          <li><a href="https://threadline.tigerapps.pro" class="hover:text-white transition-colors">{s.footer.resources_api}</a></li>
          <li><a href="mailto:support@threadline.tigerapps.pro" class="hover:text-white transition-colors">{s.footer.resources_selfhost}</a></li>
        </ul>
      </div>
      <div>
        <div class="text-[10.5px] font-semibold uppercase tracking-widest mb-3" style="color: hsl(255,8%,40%);">{s.footer.legal}</div>
        <ul class="space-y-2 text-[12.5px]" style="color: hsl(255,8%,60%);">
          <li><a href={docPath('legal/terms', lang)} class="hover:text-white transition-colors">{s.footer.legal_terms}</a></li>
          <li><a href={docPath('legal/privacy', lang)} class="hover:text-white transition-colors">{s.footer.legal_privacy}</a></li>
          <li><a href={docPath('legal/cookies', lang)} class="hover:text-white transition-colors">{s.footer.legal_cookies}</a></li>
          <li><a href={docPath('legal/refunds', lang)} class="hover:text-white transition-colors">{s.footer.legal_refunds}</a></li>
        </ul>
      </div>
    </div>
    <div class="flex items-center justify-between text-[11.5px] pt-6 hairline-top" style="color: hsl(255,8%,40%);">
      <div>{s.footer.copyright}</div>
      <div>made in <span class="text-gradient">tigerapps</span></div>
    </div>
  </div>
</footer>
