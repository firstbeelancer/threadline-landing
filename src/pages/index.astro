---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';

const features = [
  { icon: 'layers', title: 'Идеи на умной доске', body: 'Собирай ремонт квартиры, интерьер, SaaS-архитектуру, маркетинговую кампанию или дизайн-концепт на одном визуальном борде.' },
  { icon: 'cloud', title: 'Файлы не теряются', body: 'Картинки, PDF, видео, голосовые, презентации, таблицы и HTML живут как карточки: их можно открыть, скачать, заменить и развивать дальше.' },
  { icon: 'link', title: 'Связи и эволюции', body: 'Соединяй материалы линиями, сохраняй версии, добавляй референсы и напоминания, чтобы видеть не только результат, но и ход мысли.' },
  { icon: 'bot', title: 'ИИ-агенты рядом', body: 'Подключай своих ИИ-агентов через API, чтобы они помогали формулировать, раскладывать и сохранять идеи без доступа ко всему аккаунту.' },
  { icon: 'code', title: 'Работает везде', body: 'Телефон, планшет, ноутбук или рабочий компьютер — открыл браузер и продолжаешь тот же борд. Операционная система не важна.' },
  { icon: 'shield', title: 'Твои данные под контролем', body: 'Оригиналы файлов хранятся отдельно от карточек, борды можно шарить по ссылке, экспортировать архивом и удалить без ловушек.' },
];

const steps = [
  { n: '01', title: 'Создай борд', body: 'Один клик в сайдбаре. Цвет, фон, имя — что угодно. Бордов может быть сколько угодно.' },
  { n: '02', title: 'Накидывай материалы', body: 'Добавляй текст, картинки, PDF, видео, голос, ссылки и HTML. Threadline превращает материалы в понятные карточки.' },
  { n: '03', title: 'Связывай и возвращайся', body: 'Тяни линии между карточками, оставляй напоминания, подключай агента через API или шарь борд по ссылке.' },
];

const cardTypes = [
  { icon: 'sparkle', name: 'Идея', desc: 'Мысль → структура' },
  { icon: 'text', name: 'Текст', desc: 'Заметка' },
  { icon: 'image', name: 'Картинка', desc: 'Референс/макет' },
  { icon: 'video', name: 'Видео', desc: 'Превью+исходник' },
  { icon: 'code', name: 'HTML', desc: 'Прототип' },
  { icon: 'mic', name: 'Голос', desc: 'Аудио+текст' },
  { icon: 'doc', name: 'PDF/PPTX', desc: 'С превью' },
  { icon: 'plus', name: 'Свои типы', desc: 'Расширяемо' },
];

const plans = [
  {
    name: 'Бесплатный',
    price: '0',
    period: 'навсегда',
    description: 'Чтобы попробовать и понять, нужно ли тебе это вообще.',
    features: ['2 борда', '1 ГБ хранилища', 'Базовые типы карточек', 'Шаринг по ссылке'],
    cta: 'Начать бесплатно',
    href: 'https://threadline.tigerapps.pro/login',
    featured: false,
  },
  {
    name: 'Стандарт',
    price: '990',
    period: 'в месяц',
    description: 'Для тех, кто ведёт реальные проекты в Threadline.',
    features: ['20 бордов', '100 ГБ хранилища', 'ИИ-ассистент и транскрипция', 'API для своих агентов', 'Голосовые и видео-карточки'],
    cta: 'Выбрать Стандарт',
    href: 'https://threadline.tigerapps.pro/login',
    featured: true,
  },
  {
    name: 'Про',
    price: '4 990',
    period: 'в месяц',
    description: 'Без лимитов. Если Threadline — это твой основной инструмент.',
    features: ['Без ограничений по бордам', 'Хранилище без лимитов', 'Приоритет в поддержке', 'Ранний доступ к фичам', 'Кастомные интеграции'],
    cta: 'Выбрать Про',
    href: 'https://threadline.tigerapps.pro/login',
    featured: false,
  },
];

const faqs = [
  { q: 'Это облачный сервис или self-hosted?', a: 'Сейчас — облачный, на нашем сервере threadline.tigerapps.pro. Данные хранятся в PostgreSQL, файлы — в S3. Self-hosted появится позже.' },
  { q: 'Что значит «API для ИИ-агентов»?', a: 'Это granular-токены, которыми твой собственный AI-агент или скрипт дёргает Threadline API. Не нужно делиться основным паролем — выдаёшь токен с конкретными scope: только чтение бордов, только запись карточек и так далее.' },
  { q: 'Чем это отличается от Miro / FigJam?', a: 'Miro и FigJam в первую очередь про совместную доску. Threadline — про личное и проектное пространство, где доска хранит не только схему, но и оригиналы файлов, референсы, версии, заметки, связи и материалы, которые можно скачать или обновить.' },
  { q: 'Для каких задач это подходит?', a: 'Для интерьера и ремонта, дизайна, маркетинга, разработки SaaS, стройки, исследований, контента и любых проектов, где нужно видеть идею вместе с материалами, файлами и логикой решений.' },
  { q: 'Можно ли экспортировать всё, если я уйду?', a: 'Да. Settings → Данные → «Экспортировать все борды одним архивом» — получаешь один ZIP со всеми бордами, метаданными и оригиналами файлов.' },
  { q: 'Что с приватностью?', a: 'Аккаунт и OAuth-сессии изолированы, файлы — в нашем S3, доступ только у тебя. Hard delete удаляет всё физически. Мы не читаем твои борды.' },
];
---

<BaseLayout>
  <Header />

  <main>
    <!-- ============ HERO ============ -->
    <section class="hero relative pt-[160px] pb-24 px-6">
      <div class="max-w-[860px] mx-auto text-center">
        <div class="eyebrow reveal">
          <span class="text-[11.5px] font-medium">Визуальная доска для идей, файлов и проектов</span>
        </div>
        <h1 class="font-display text-[58px] sm:text-[72px] font-bold leading-[0.96] tracking-[-0.02em] mb-6 reveal">
          Собирай идеи<br />
          <span class="text-gradient">в живую карту проекта</span>
        </h1>
        <p class="text-[16.5px] leading-relaxed max-w-[600px] mx-auto mb-10 reveal" style="color: hsl(255,8%,68%);">
          Threadline — не сложный конструктор и не просто mind map. Это удобное пространство,
          где можно собрать интерьер, ремонт, маркетинговую идею или SaaS-систему: прикреплять
          файлы разных форматов, связывать их, обновлять, скачивать и продолжать с любого устройства.
        </p>
        <div class="flex items-center justify-center gap-3 flex-wrap reveal">
          <a
            href="https://threadline.tigerapps.pro/login"
            class="cta-primary"
          >
            <Icon name="rocket" size={16} class="shrink-0" />
            Начать бесплатно
          </a>
          <a
            href="#features"
            class="cta-ghost"
          >
            Посмотреть как устроено
            <Icon name="arrow" size={14} class="shrink-0" />
          </a>
        </div>

        <div class="relative mt-20 mx-auto max-w-[920px] mockup reveal">
          <div class="mockup-bar">
            <div class="flex gap-1.5">
              <span class="dot" style="background: rgba(239,68,68,0.5);"></span>
              <span class="dot" style="background: rgba(234,179,8,0.5);"></span>
              <span class="dot" style="background: rgba(16,185,129,0.5);"></span>
            </div>
            <div class="mockup-url">threadline.tigerapps.pro/board/прототип-v2</div>
          </div>
          <div class="mockup-body">
            <aside class="mockup-sidebar">
              <div class="text-[9.5px] uppercase tracking-widest mb-1.5" style="color: hsl(255,8%,40%);">Борды</div>
              <div class="mockup-board active">
                <span class="dot" style="background: #6D4ADE; box-shadow: 0 0 6px #6D4ADE;"></span>
                Прототип v2
              </div>
              <div class="mockup-board">
                <span class="dot" style="background: #42DFC1; box-shadow: 0 0 6px #42DFC1;"></span>
                Research — UX
              </div>
              <div class="mockup-board">
                <span class="dot" style="background: #F97316; box-shadow: 0 0 6px #F97316;"></span>
                Roadmap Q3
              </div>
            </aside>
            <main class="mockup-canvas">
              <svg viewBox="0 0 600 420" class="absolute inset-0 w-full h-full">
                <defs>
                  <linearGradient id="line" x1="0" x2="1">
                    <stop offset="0" stop-color="#42DFC1" stop-opacity="0.6"></stop>
                    <stop offset="1" stop-color="#6D4ADE" stop-opacity="0.5"></stop>
                  </linearGradient>
                </defs>
                <path d="M 170 90 C 280 90, 280 200, 380 200" stroke="url(#line)" stroke-width="1.5" fill="none"></path>
                <path d="M 170 90 C 280 90, 280 320, 380 320" stroke="url(#line)" stroke-width="1.5" fill="none"></path>
                <path d="M 380 200 C 460 200, 460 260, 510 260" stroke="url(#line)" stroke-width="1.5" fill="none"></path>
              </svg>
              <div class="mock-card" style="left: 60px; top: 50px; --accent: #6D4ADE;">
                <div class="mock-card-icon" style="background: rgba(109,74,222,0.24); color: #6D4ADE;"><Icon name="sparkle" size={8} /></div>
                <div class="mock-card-title">Промт: Hero-секция</div>
                <div class="mock-card-body">Сгенерируй текст для лендинга в стиле Vercel...</div>
              </div>
              <div class="mock-card" style="left: 280px; top: 160px; --accent: #42DFC1;">
                <div class="mock-card-icon" style="background: rgba(66,223,193,0.24); color: #42DFC1;"><Icon name="code" size={8} /></div>
                <div class="mock-card-title">HTML: лендинг</div>
                <div class="mock-card-body">&lt;section class='hero'&gt;...&lt;/section&gt;</div>
              </div>
              <div class="mock-card" style="left: 280px; top: 280px; --accent: #42DFC1;">
                <div class="mock-card-icon" style="background: rgba(66,223,193,0.24); color: #42DFC1;"><Icon name="image" size={8} /></div>
                <div class="mock-card-title">Image: макет</div>
                <div class="mock-card-body">mockup-v3.png</div>
              </div>
              <div class="mock-card" style="left: 420px; top: 220px; --accent: #EAB308;">
                <div class="mock-card-icon" style="background: rgba(234,179,8,0.24); color: #EAB308;"><Icon name="mic" size={8} /></div>
                <div class="mock-card-title">Голос: правки</div>
                <div class="mock-card-body">0:42 — укоротить intro</div>
              </div>
            </main>
            <aside class="mockup-detail">
              <div class="text-[9.5px] uppercase tracking-widest mb-2" style="color: hsl(255,8%,40%);">Детали карточки</div>
              <div class="text-[11px] font-semibold mb-2" style="color: hsl(260, 20%, 92%);">HTML: лендинг</div>
              <div class="badge-mint">html</div>
              <pre class="text-[9.5px] font-mono p-2 rounded-[5px] mt-2" style="background: hsl(240, 20%, 9%); color: hsl(255,8%,60%);">{`<div class="hero">
  <h1>...</h1>
  <p>...</p>
</div>`}</pre>
            </aside>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ TRUST ============ -->
    <section class="px-6 py-10">
      <div class="max-w-[1100px] mx-auto">
        <div class="text-[10.5px] uppercase tracking-[0.18em] text-center mb-6" style="color: hsl(255,8%,40%);">
          Сделано для тех, кто думает визуально
        </div>
        <div class="flex items-center justify-center gap-x-12 gap-y-4 flex-wrap text-[12.5px] font-medium" style="color: hsl(255,8%,50%);">
          <span class="inline-flex items-center gap-1.5"><Icon name="robot" size={14} />Креаторы</span>
          <span class="inline-flex items-center gap-1.5"><Icon name="terminal" size={14} />Разработчики</span>
          <span class="inline-flex items-center gap-1.5"><Icon name="brush" size={14} />Дизайнеры</span>
          <span class="inline-flex items-center gap-1.5"><Icon name="mic" size={14} />Строители</span>
          <span class="inline-flex items-center gap-1.5"><Icon name="pencil" size={14} />Маркетологи</span>
        </div>
      </div>
    </section>

    <!-- ============ FEATURES ============ -->
    <section id="features" class="px-6 py-24">
      <div class="max-w-[1100px] mx-auto">
        <div class="text-center max-w-[640px] mx-auto">
          <div class="section-eyebrow">Фичи</div>
          <h2 class="section-title">Не просто майнд-мэпер</h2>
          <p class="section-desc">Threadline хранит не только схему, но и сами материалы: файлы, ссылки, заметки, голос, версии и связи между ними.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 mt-12">
          {features.map((f) => (
            <article class="feature-card reveal">
              <div class="feature-icon">
                <Icon name={f.icon} size={16} />
              </div>
              <h3 class="text-[14.5px] font-semibold mb-1.5" style="color: hsl(260, 20%, 92%);">{f.title}</h3>
              <p class="text-[12.5px] leading-relaxed" style="color: hsl(255,8%,62%);">{f.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ HOW ============ -->
    <section id="how" class="px-6 py-24" style="background: hsl(240, 30%, 5%);">
      <div class="max-w-[1100px] mx-auto">
        <div class="text-center max-w-[640px] mx-auto">
          <div class="section-eyebrow">Как это работает</div>
          <h2 class="section-title">Три шага до твоего первого борда</h2>
          <p class="section-desc">Без onboarding-тура, без обучения. Открыл → создал борд → потащил карточки.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-12">
          {steps.map((s) => (
            <article class="step-card reveal">
              <div class="step-num text-gradient">{s.n}</div>
              <h3 class="text-[15px] font-semibold mb-2" style="color: hsl(260, 20%, 92%);">{s.title}</h3>
              <p class="text-[13px] leading-relaxed" style="color: hsl(255,8%,62%);">{s.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ CARD TYPES ============ -->
    <section class="px-6 py-24">
      <div class="max-w-[1100px] mx-auto">
        <div class="text-center max-w-[640px] mx-auto">
          <div class="section-eyebrow">Типы карточек</div>
          <h2 class="section-title">Любой материал — в одном месте</h2>
          <p class="section-desc">Каждая карточка — это мысль, файл или референс. Связи показывают, как идея развивается от первого наброска до решения.</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-12">
          {cardTypes.map((t) => (
            <article class="type-card reveal">
              <div class="type-icon">
                <Icon name={t.icon} size={16} />
              </div>
              <div class="text-[12.5px] font-semibold mb-0.5" style="color: hsl(260, 20%, 92%);">{t.name}</div>
              <div class="text-[10.5px]" style="color: hsl(255,8%,50%);">{t.desc}</div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ PRICING ============ -->
    <section id="pricing" class="px-6 py-24" style="background: hsl(240, 30%, 5%);">
      <div class="max-w-[1100px] mx-auto">
        <div class="text-center max-w-[640px] mx-auto">
          <div class="section-eyebrow">Тарифы</div>
          <h2 class="section-title">Плати только когда выйдешь за пределы бесплатного</h2>
          <p class="section-desc">Бесплатного тарифа хватает, чтобы попробовать. Стандарт — для большинства. Про — для тех, кто живёт в Threadline.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-12">
          {plans.map((p) => (
            <article class={`plan-card ${p.featured ? 'featured' : ''} reveal`}>
              {p.featured && <div class="plan-badge">Популярный</div>}
              <div class={`text-[13px] font-semibold mb-1 ${p.featured ? 'text-mint' : ''}`}>{p.name}</div>
              <div class="flex items-baseline gap-1.5 mb-2">
                <span class="font-display text-[44px] font-bold leading-none tracking-tight" style="color: hsl(260, 20%, 95%);">{p.price}</span>
                <span class="text-[12px]" style="color: hsl(255,8%,50%);">₽ {p.period}</span>
              </div>
              <p class="text-[12.5px] leading-relaxed mb-5 min-h-[36px]" style="color: hsl(255,8%,60%);">{p.description}</p>
              <ul class="space-y-2.5 mb-6">
                {p.features.map((feat) => (
                  <li class="flex items-start gap-2 text-[12.5px]" style="color: hsl(260, 20%, 88%);">
                    <span class={p.featured ? 'check-mint' : 'check-violet'}><Icon name='check' size={14} /></span>
                    <span>{feat}</span>
                  </li>
                ))}
              </ul>
              <a
                href={p.href}
                class={`plan-cta ${p.featured ? 'plan-cta-featured' : 'plan-cta-ghost'}`}
              >{p.cta}</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section id="faq" class="px-6 py-24">
      <div class="max-w-[800px] mx-auto">
        <div class="text-center max-w-[640px] mx-auto">
          <div class="section-eyebrow">FAQ</div>
          <h2 class="section-title">Частые вопросы</h2>
          <p class="section-desc">Если не нашёл ответа — напиши в поддержку, ответим быстро.</p>
        </div>
        <div class="space-y-2 mt-12">
          {faqs.map((f, i) => (
            <details class="faq-item reveal" open={i === 0}>
              <summary>
                <span>{f.q}</span>
                <span class="faq-chevron"><Icon name="chevron" size={14} /></span>
              </summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FINAL CTA ============ -->
    <section class="px-6 py-24">
      <div class="max-w-[860px] mx-auto">
        <div class="cta-card">
          <div class="cta-glow"></div>
          <h2 class="font-display text-[36px] sm:text-[44px] font-bold leading-[1.05] tracking-[-0.02em] mb-4 relative">Готов попробовать?</h2>
          <p class="text-[15px] max-w-[460px] mx-auto mb-8 relative" style="color: hsl(255,8%,68%);">
            Бесплатно, без карты. Два борда и 1 ГБ хватит, чтобы собрать первую идею с файлами, связями и референсами.
          </p>
          <div class="flex items-center justify-center gap-3 relative">
            <a href="https://threadline.tigerapps.pro/login" class="cta-primary">
              <Icon name="rocket" size={16} class="shrink-0" />
              Создать аккаунт
            </a>
            <a href="https://threadline.tigerapps.pro/login" class="cta-ghost">У меня уже есть аккаунт</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero {
    background:
      radial-gradient(ellipse 60% 50% at 20% 0%, rgba(66,223,193,0.10) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 5%, rgba(109,74,222,0.14) 0%, transparent 60%),
      radial-gradient(ellipse 70% 50% at 50% 100%, rgba(66,8,129,0.16) 0%, transparent 70%);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.75rem;
    height: 30px;
    border-radius: 9999px;
    margin-bottom: 1.75rem;
    background: linear-gradient(135deg, rgba(66,223,193,0.10) 0%, rgba(109,74,222,0.14) 100%);
    border: 1px solid rgba(66,223,193,0.22);
    color: #42DFC1;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.25rem;
    height: 44px;
    border-radius: 10px;
    font-size: 13.5px;
    font-weight: 600;
    color: white;
    background: var(--brand-gradient);
    box-shadow: 0 0 32px rgba(66,223,193,0.32), inset 0 0 0 1px rgba(255,255,255,0.06);
    transition: transform 0.15s ease;
  }
  .cta-primary:hover { transform: translateY(-1px); }

  .cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.25rem;
    height: 44px;
    border-radius: 10px;
    font-size: 13.5px;
    font-weight: 500;
    color: hsl(255,8%,78%);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.15s ease;
  }
  .cta-ghost:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.14);
  }

