---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { detectLang, getStrings } from '../../../i18n/dict';

const lang = 'en' as const;
const s = getStrings(lang);
const posts = s.blog.welcome.posts;
---

<BaseLayout lang={lang} title={`${s.blog.title} — THREADLINE`} description={s.blog.intro}>
  <Header lang={lang} basePath="/blog" />
  <main class="pt-[140px] pb-24 px-6">
    <div class="max-w-[800px] mx-auto">
      <div class="section-eyebrow">{s.blog.title}</div>
      <h1 class="font-display text-[44px] font-bold leading-[1.05] tracking-[-0.02em] mb-3">{s.blog.intro.split('.')[0]}.</h1>
      <p class="text-[15px] mb-12" style="color: hsl(255,8%,65%);">{s.blog.intro}</p>
      <div class="space-y-4">
        {posts.map((p) => (
          <a href={lang === 'en' ? `/en/blog/${p.slug}` : `/blog/${p.slug}`} class="block surface-card p-5 hover:bg-white/[0.04] transition-colors">
            <div class="text-[11px] mb-1" style="color: hsl(255,8%,40%);">{new Date(p.date).toLocaleDateString(lang === 'en' ? 'en-US' : 'ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
            <h2 class="text-[18px] font-semibold mb-1" style="color: hsl(260, 20%, 92%);">{p.title}</h2>
            <p class="text-[13.5px]" style="color: hsl(255,8%,62%);">{p.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>
