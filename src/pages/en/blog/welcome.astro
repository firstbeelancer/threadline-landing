---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { detectLang, getStrings } from '../../../i18n/dict';

const lang = 'en' as const;
const s = getStrings(lang);
const post = s.blog.welcome;
const dateLabel = new Date('2026-06-01').toLocaleDateString(lang === 'en' ? 'en-US' : 'ru-RU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout lang={lang} title={`${post.title} — THREADLINE`} description={post.lead}>
  <Header lang={lang} basePath="/blog" />
  <main class="pt-[140px] pb-24 px-6">
    <article class="max-w-[720px] mx-auto">
      <a href={lang === 'en' ? '/en/blog' : '/blog'} class="text-[12px] hover:text-white" style="color: hsl(255,8%,50%);">← {s.blog.backToBlog}</a>
      <div class="text-[11px] mt-4 mb-1" style="color: hsl(255,8%,40%);">{dateLabel}</div>
      <h1 class="font-display text-[40px] font-bold leading-[1.05] tracking-[-0.02em] mb-3">{post.title}</h1>
      <p class="text-[16px] leading-relaxed mb-6" style="color: hsl(255,8%,68%);">
        {post.lead}
      </p>
      <h2 class="font-display text-[24px] font-semibold mb-3 mt-8">{post.h_why}</h2>
      <p class="text-[15px] leading-relaxed mb-4" style="color: hsl(255,8%,68%);">
        {post.why_p1}
      </p>
      <p class="text-[15px] leading-relaxed mb-4" style="color: hsl(255,8%,68%);">
        {post.why_p2}
      </p>
      <h2 class="font-display text-[24px] font-semibold mb-3 mt-8">{post.h_next}</h2>
      <p class="text-[15px] leading-relaxed" style="color: hsl(255,8%,68%);">
        {post.next_p1}
      </p>
    </article>
  </main>
  <Footer lang={lang} />
</BaseLayout>
