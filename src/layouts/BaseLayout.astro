---
import '../styles/global.css';
import { detectLang, getStrings, type Lang } from '../i18n/dict';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  lang?: Lang;
}

const detectedLang = detectLang(Astro.url.pathname);
const {
  lang = detectedLang,
} = Astro.props;

const strings = getStrings(lang);

const {
  title = strings.meta.title,
  description = strings.meta.description,
  canonical = (lang === 'en' ? 'https://threadline.tigerapps.pro/en/' : 'https://threadline.tigerapps.pro/'),
  ogImage = 'https://threadline.tigerapps.pro/og-cover.png',
} = Astro.props;

const siteName = 'THREADLINE';
const fullTitle = title.includes('THREADLINE') ? title : `${title} — ${siteName}`;
---

<!doctype html>
<html lang={lang === 'en' ? 'en' : 'ru'} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a14" />
    <meta name="color-scheme" content="dark" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'ru_RU'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <!-- JSON-LD: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'THREADLINE',
      applicationCategory: 'ProductivityApplication',
      operatingSystem: 'Web',
      description,
      url: 'https://threadline.tigerapps.pro',
      offers: lang === 'en' ? [
        { '@type': 'Offer', name: 'Free', price: '0', priceCurrency: 'USD' },
        { '@type': 'Offer', name: 'Standard', price: '8', priceCurrency: 'USD' },
        { '@type': 'Offer', name: 'Pro', price: '24', priceCurrency: 'USD' },
      ] : [
        { '@type': 'Offer', name: 'Бесплатный', price: '0', priceCurrency: 'RUB' },
        { '@type': 'Offer', name: 'Стандарт', price: '990', priceCurrency: 'RUB' },
        { '@type': 'Offer', name: 'Про', price: '4990', priceCurrency: 'RUB' },
      ],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', ratingCount: '42' },
    })}></script>

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'THREADLINE',
      url: 'https://threadline.tigerapps.pro',
      logo: 'https://threadline.tigerapps.pro/icon-192.png',
      sameAs: [],
    })}></script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-deep: 240 33% 4%;
    --bg-base: 240 25% 6%;
    --bg-surface: 240 20% 9%;

    --border-subtle: hsla(255, 12%, 100%, 0.08);
    --hairline: hsla(255, 12%, 100%, 0.05);
    --text-low: hsl(255, 8%, 60%);
    --text-base: hsl(255, 8%, 70%);
    --text-bright: hsl(255, 12%, 90%);

    --brand-mint: #42DFC1;
    --brand-violet: #6D4ADE;
    --brand-indigo: #420881;

    --brand-gradient: linear-gradient(135deg, #42DFC1 0%, #6D4ADE 50%, #420881 100%);
    --brand-gradient-text: linear-gradient(135deg, #42DFC1 0%, #6D4ADE 100%);

    --font-display: 'Space Grotesk', 'Inter', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', 'SF Mono', monospace;
  }

  html, body {
    background: var(--bg-deep);
    color: var(--text-bright);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
  }
  body {
    min-height: 100vh;
  }

  .font-display { font-family: var(--font-display); letter-spacing: -0.015em; }
  .text-gradient {
    background: var(--brand-gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  ::selection { background: rgba(66,223,193,0.32); color: hsl(255, 12%, 96%); }
  a { color: inherit; text-decoration: none; }
  button { font-family: inherit; }

  .hairline-top { border-top: 1px solid var(--hairline); }
  .hairline-bottom { border-bottom: 1px solid var(--hairline); }

  .reveal {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.in { opacity: 1; transform: translateY(0); }
</style>
