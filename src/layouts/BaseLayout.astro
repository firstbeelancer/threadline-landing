---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  lang?: string;
  ogLocale?: string;
}

const {
  title = 'THREADLINE — визуальная доска для идей, файлов и проектов',
  description = 'Threadline помогает собирать идеи, файлы, референсы и заметки на умных визуальных бордах: от ремонта квартиры до SaaS-продукта. Работает в браузере на телефоне, планшете и компьютере, поддерживает связи между материалами и подключение ИИ-агентов.',
  canonical = 'https://threadline.tigerapps.pro/',
  ogImage = 'https://threadline.tigerapps.pro/og-cover.png',
  lang = 'ru',
  ogLocale = 'ru_RU',
} = Astro.props;

const siteName = 'THREADLINE';
const fullTitle = title.includes('THREADLINE') ? title : `${title} — ${siteName}`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a14" />
    <meta name="color-scheme" content="dark" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <!-- JSON-LD: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'THREADLINE',
      applicationCategory: 'ProductivityApplication',
      operatingSystem: 'Web',
      description,
      url: 'https://threadline.tigerapps.pro',
      offers: [
        { '@type': 'Offer', name: 'Бесплатный', price: '0', priceCurrency: 'RUB' },
        { '@type': 'Offer', name: 'Стандарт', price: '990', priceCurrency: 'RUB' },
        { '@type': 'Offer', name: 'Про', price: '4990', priceCurrency: 'RUB' },
      ],
      aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', ratingCount: '42' },
    })}></script>

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'THREADLINE',
      url: 'https://threadline.tigerapps.pro',
      logo: 'https://threadline.tigerapps.pro/icon-192.png',
      sameAs: [],
    })}></script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-deep: 240 33% 4%;
    --bg-base: 240 25% 6%;
    --bg-surface: 240 20% 9%;
    --bg-elevated: 240 17% 12%;
    --bg-hover: 240 20% 16%;

    --text-primary: 260 20% 92%;
    --text-secondary: 255 8% 70%;
    --text-muted: 255 8% 50%;
    --text-label: 255 8% 40%;
    --text-ghost: 255 8% 35%;

    --border-subtle: rgba(255, 255, 255, 0.05);
    --border-default: rgba(255, 255, 255, 0.08);
    --border-hover: rgba(255, 255, 255, 0.12);

    --mint: #42DFC1;
    --violet: #6D4ADE;
    --indigo: #420881;

    --brand-gradient: linear-gradient(135deg, #42DFC1 0%, #6D4ADE 55%, #420881 100%);
    --brand-gradient-soft: linear-gradient(135deg, rgba(66,223,193,0.16) 0%, rgba(109,74,222,0.18) 55%, rgba(66,8,129,0.22) 100%);
    --brand-gradient-text: linear-gradient(135deg, #42DFC1 0%, #8E72E6 50%, #420881 100%);
  }

  * { box-sizing: border-box; }

  html, body { margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  section[id] { scroll-margin-top: 84px; }
  body {
    position: relative;
    background:
      linear-gradient(180deg, hsl(240, 33%, 4%) 0%, hsl(242, 32%, 4%) 42%, hsl(240, 33%, 4%) 100%);
    color: hsl(260, 20%, 92%);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: 'cv11', 'ss01', 'ss03';
    overflow-x: hidden;
    min-height: 100vh;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 36% at 18% 0%, rgba(66,223,193,0.11) 0%, rgba(66,223,193,0.04) 34%, transparent 68%),
      radial-gradient(ellipse 54% 32% at 84% 8%, rgba(109,74,222,0.16) 0%, rgba(109,74,222,0.05) 36%, transparent 70%),
      radial-gradient(ellipse 72% 38% at 50% 30%, rgba(66,8,129,0.14) 0%, rgba(66,8,129,0.045) 42%, transparent 76%),
      radial-gradient(ellipse 58% 34% at 10% 58%, rgba(66,223,193,0.075) 0%, transparent 72%),
      radial-gradient(ellipse 62% 36% at 92% 72%, rgba(109,74,222,0.12) 0%, transparent 72%),
      radial-gradient(ellipse 70% 38% at 50% 100%, rgba(66,8,129,0.18) 0%, transparent 76%);
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(7,7,13,0.08) 0%, rgba(7,7,13,0.34) 58%, rgba(7,7,13,0.18) 100%);
  }
  body > * {
    position: relative;
    z-index: 0;
  }
  ::selection { background: rgba(109, 74, 222, 0.32); color: hsl(260, 20%, 92%); }
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(66, 223, 193, 0.18); border-radius: 8px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(66, 223, 193, 0.32); }

  .font-display { font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif; }
  .font-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }

  .text-gradient {
    background: var(--brand-gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .bg-brand { background: var(--brand-gradient); }
  .bg-brand-soft { background: var(--brand-gradient-soft); }

  .ring-glow {
    box-shadow:
      0 0 0 1px rgba(66, 223, 193, 0.45),
      0 0 24px rgba(66, 223, 193, 0.20);
  }

  .surface-card {
    background: hsl(240, 25%, 7%);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 1px 1px rgba(0, 0, 0, 0.20),
      0 8px 24px rgba(0, 0, 0, 0.30);
  }

  .hairline-bottom { border-bottom: 1px solid var(--border-subtle); }
  .hairline-top { border-top: 1px solid var(--border-subtle); }

  a { color: inherit; text-decoration: none; }
  button { font-family: inherit; cursor: pointer; }

  /* Reveal-on-scroll */
  .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>
